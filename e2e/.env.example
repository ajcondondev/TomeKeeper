# TomeKeeper E2E Environment Variables
# Copy this file to e2e/.env and fill in values for local development.
# Never commit e2e/.env — it is gitignored.

# ---------------------------------------------------------------------------
# Application URLs
# ---------------------------------------------------------------------------

# Frontend base URL (Playwright navigates here)
BASE_URL=http://localhost:5173

# Backend API base URL (used by ApiHelper for setup/teardown)
API_URL=http://localhost:3001

# ---------------------------------------------------------------------------
# Shared test user
# Credentials for the persistent test account created once by auth.setup.ts.
# This user's library accumulates data unless tests clean up after themselves.
# ---------------------------------------------------------------------------

TEST_EMAIL=e2e-shared@tomekeeper.dev
TEST_PASSWORD=SecurePass123!
